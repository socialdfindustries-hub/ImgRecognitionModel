# --- SECRETS: never commit signing keys ---
keys/*
!keys/.gitkeep
*_ed25519
*.pem

# --- model artifacts (large / sensitive weights) ---
dist/
*.safetensors
*.onnx
*.engine
*.pt
*.pth

# --- datasets (untrusted, large; pin via hash manifests instead) ---
# NOTE: leading slash anchors this to the REPO ROOT only, so it ignores the
# top-level dataset dir but NOT the src/data/ source package.
/data/
!/data/manifests/

# --- scratch / prediction outputs ---
scratch_*.jpg
prediction*.jpg

# --- python ---
__pycache__/
*.pyc
.venv/
venv/
.env

# local training scratch (not for the repo)
data_src/
*.log
watch_training.sh
TRAINING_DONE.txt

# --- SECURITY: quarantined / suspected-malicious artifacts, NEVER commit ---
*_QUARANTINE_*/
.venv_QUARANTINE_trojaned/

# --- raw dataset directories & archives (huge, untrusted; hash-pin instead) ---
/VisDrone2019-DET-train/
/VisDrone2019-DET-val/
*.zip

# --- media / inference outputs (annotated videos, sample frames) ---
*.mp4
*.avi
*.mov
*.mkv
webcam_frames/
