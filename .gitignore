# --- SECRETS: never commit signing keys ---
keys/*
!keys/.gitkeep
*_ed25519
*.pem

# --- model artifacts (large / sensitive weights) ---
dist/
*.safetensors
*.onnx
*.engine
*.pt
*.pth

# --- datasets (untrusted, large; pin via hash manifests instead) ---
data/
!data/manifests/

# --- scratch / prediction outputs ---
scratch_*.jpg
prediction*.jpg

# --- python ---
__pycache__/
*.pyc
.venv/
venv/
.env
